# ══════════════════════════════════════════════════════════════
# Variables d'environnement — Obstetric RAG Pipeline
# Copier en .env et remplir les valeurs
# ══════════════════════════════════════════════════════════════

# NCBI / PubMed (gratuit — https://www.ncbi.nlm.nih.gov/account/settings/)
# Sans clé : 3 req/s | Avec clé : 10 req/s
NCBI_API_KEY=your_ncbi_api_key_here

# Semantic Scholar (gratuit sur demande — https://www.semanticscholar.org/product/api)
S2_API_KEY=your_semantic_scholar_key_here

# NICE Syndication API (demande à api@nice.org.uk)
NICE_API_KEY=your_nice_api_key_here

# CORE API (gratuit — https://core.ac.uk/services/api)
CORE_API_KEY=your_core_api_key_here

# OpenAI Embeddings (optionnel — si vous préférez à sentence-transformers)
# OPENAI_API_KEY=sk-...
